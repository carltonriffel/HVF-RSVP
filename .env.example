# ---------------------------------------------------------------------------
# Happy Valley Farms – Planner Retreat RSVP
# Copy this file to ".env.local" and fill in the values. Never commit .env.local
# ---------------------------------------------------------------------------

# The deployed Google Apps Script "Web app" URL.
# (Apps Script editor → Deploy → New deployment → Web app → copy the URL.)
# It looks like: https://script.google.com/macros/s/AKfy..../exec
APPS_SCRIPT_URL=

# The shared secret. This MUST match SHARED_SECRET at the top of the
# Apps Script (apps-script/Code.gs). Use a long random string.
APPS_SCRIPT_SECRET=

# ---------------------------------------------------------------------------
# Only needed when deploying under a sub-path (e.g. Webflow Cloud at
# /planner-rsvp). Leave blank for local development to serve from "/".
# NEXT_PUBLIC_BASE_PATH=/planner-rsvp
# ---------------------------------------------------------------------------
